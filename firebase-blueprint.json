{
  "entities": {
    "GlobalSettings": {
      "title": "Global Settings",
      "description": "학교 링크 및 시험 정보를 포함하는 전역 설정",
      "type": "object",
      "properties": {
        "timetableLink": { "type": "string", "description": "시간표 링크" },
        "kakaoLink": { "type": "string", "description": "카톡방 링크" },
        "schoolWebsiteLink": { "type": "string", "description": "학교 홈페이지 링크" },
        "nextExamDate": { "type": "string", "format": "date", "description": "다음 시험 날짜" },
        "nextExamTitle": { "type": "string", "description": "다음 시험 이름" },
        "peDays": { "type": "array", "items": { "type": "integer" }, "description": "체육복 가져오는 요일 (0:일, 1:월...)" },
        "extraLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string", "description": "링크 제목" },
              "url": { "type": "string", "description": "링크 URL" }
            },
            "required": ["title", "url"]
          },
          "description": "추가 커스텀 링크 목록"
        }
      },
      "required": ["timetableLink", "kakaoLink"]
    },
    "Notice": {
      "title": "Notice",
      "description": "학교 공지 사항",
      "type": "object",
      "properties": {
        "content": { "type": "string", "description": "공지 내용" },
        "type": { "type": "string", "enum": ["general", "teacher"], "description": "공지 유형" },
        "createdAt": { "type": "string", "format": "date-time", "description": "작성 시간" }
      },
      "required": ["content", "type", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "시험, 행사, 생일 일정",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "일정 제목" },
        "date": { "type": "string", "format": "date", "description": "일정 날짜" },
        "type": { "type": "string", "enum": ["exam", "event", "birthday"], "description": "일정 유형" }
      },
      "required": ["title", "date", "type"]
    },
    "ContentRequest": {
      "title": "Content Request",
      "description": "사용자의 내용 추가 요청",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "요청 내용" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "approved"], "description": "처리 상태" },
        "authorEmail": { "type": "string", "format": "email", "description": "요청자 이메일" },
        "createdAt": { "type": "string", "format": "date-time", "description": "요청 시간" }
      },
      "required": ["text", "status", "authorEmail", "createdAt"]
    },
    "PerformanceAssessment": {
      "title": "Performance Assessment",
      "description": "과목별 수행평가 정보",
      "type": "object",
      "properties": {
        "subject": { "type": "string", "description": "과목명" },
        "title": { "type": "string", "description": "수행평가 제목" },
        "dueDate": { "type": "string", "format": "date", "description": "마감 기한" },
        "description": { "type": "string", "description": "상세 설명" },
        "createdAt": { "type": "string", "format": "date-time", "description": "작성 시간" }
      },
      "required": ["subject", "title", "dueDate", "createdAt"]
    },
    "ExamRange": {
      "title": "Exam Range",
      "description": "과목별 시험 범위 정보",
      "type": "object",
      "properties": {
        "subject": { "type": "string", "description": "과목명" },
        "range": { "type": "string", "description": "시험 범위" },
        "examTitle": { "type": "string", "description": "시험 명칭 (예: 중간고사)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "작성 시간" }
      },
      "required": ["subject", "range", "examTitle", "createdAt"]
    }
  },
  "firestore": {
    "/settings/global": {
      "schema": "GlobalSettings",
      "description": "전역 설정 문서"
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "공지 사항 컬렉션"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "일정 컬렉션"
    },
    "/requests/{requestId}": {
      "schema": "ContentRequest",
      "description": "내용 추가 요청 컬렉션"
    },
    "/performance_assessments/{id}": {
      "schema": "PerformanceAssessment",
      "description": "수행평가 컬렉션"
    },
    "/exam_ranges/{id}": {
      "schema": "ExamRange",
      "description": "시험 범위 컬렉션"
    }
  }
}
