rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: global
    // Fields:
    //   - timetableLink: string (required)
    //   - kakaoLink: string (required)
    //   - nextExamDate: string (optional, ISO date)
    //   - nextExamTitle: string (optional)
    //
    // Collection: notices
    // Fields:
    //   - content: string (required, max 500)
    //   - createdAt: timestamp (required)
    //
    // Collection: schedules
    // Fields:
    //   - title: string (required, max 100)
    //   - date: string (required, ISO date)
    //   - type: string (required, enum: ['exam', 'event', 'birthday'])
    //
    // Collection: requests
    // Fields:
    //   - text: string (required, max 1000)
    //   - status: string (required, enum: ['pending', 'in_progress', 'approved'])
    //   - authorEmail: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "slgdj1228@gmail.com" && request.auth.token.email_verified == true);
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    // Global Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Notices
    match /notices/{noticeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Schedules
    match /schedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Requests
    match /requests/{requestId} {
      // Users can see all requests (as per requirement "자기가 한걸 볼수잇게하고" - simplified to public read for now, or could be filtered)
      // Actually, user should see their own, but the prompt says "사용자가 쓰고 자기가 한걸 볼수잇게하고"
      // We'll allow read if authenticated for now, or filter by email in the UI.
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
        request.resource.data.authorEmail == request.auth.token.email &&
        request.resource.data.status == "pending";
        
      allow update: if isAdmin(); // Only admin can change status
      allow delete: if isAdmin() || isOwner(resource.data.authorEmail);
    }

    // Performance Assessments
    match /performance_assessments/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Exam Ranges
    match /exam_ranges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
